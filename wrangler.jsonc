{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "met-roulette",
  "compatibility_date": "2026-06-01",
  // Static-assets-only Worker — no server code. `npx expo export --platform web`
  // writes the site to ./dist, which Cloudflare serves directly.
  "assets": {
    "directory": "./dist"
  }
}
